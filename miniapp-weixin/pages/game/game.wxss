@import './game-door.wxss';
@import './game-items.wxss';
@import './game-bubble.wxss';
@import './game-chapter-transition.wxss';
@import './game-level-intro.wxss';
@import './game-recipe-book.wxss';
@import './game-basic-completion.wxss';
@import './game-trade-station.wxss';

page {
  height: 100%;
  overflow: hidden;
}

/* 布局变量由 utils/game-layout.js + pages/game/game.js 注入，对齐 H5 固定 px 高度 */

.game-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  overflow: hidden;
  box-sizing: border-box;
  background: var(--chapter-bg, #FDF8E8);
}

/* 章节主题变量 — 对齐 H5 game-base.css */
.game-page.theme-dairy {
  --chapter-bg: #FDF8E8;
  --chapter-glow: rgba(232, 200, 115, 0.2);
  --chapter-edge-glow: rgba(232, 200, 115, 0.14);
}

.game-page.theme-floral {
  --chapter-bg: #FDF0F2;
  --chapter-glow: rgba(212, 160, 168, 0.2);
  --chapter-edge-glow: rgba(212, 160, 168, 0.14);
}

.game-page.theme-fruit {
  --chapter-bg: #F0F5EC;
  --chapter-glow: rgba(123, 163, 123, 0.2);
  --chapter-edge-glow: rgba(123, 163, 123, 0.14);
}

.game-page.theme-grain {
  --chapter-bg: #F8F2E4;
  --chapter-glow: rgba(212, 160, 58, 0.2);
  --chapter-edge-glow: rgba(212, 160, 58, 0.14);
}

.game-page.theme-temperature {
  --chapter-bg: #EDF4F7;
  --chapter-glow: rgba(137, 180, 200, 0.2);
  --chapter-edge-glow: rgba(137, 180, 200, 0.14);
}

.game-page.theme-ultimate {
  --chapter-bg: #FDF4EC;
  --chapter-glow: rgba(232, 168, 124, 0.2);
  --chapter-edge-glow: rgba(232, 168, 124, 0.14);
}

.back-btn {
  position: relative;
  width: 84rpx;
  height: 84rpx;
  background: rgba(255, 253, 247, 0.92);
  border: 2rpx solid rgba(166, 124, 82, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(107, 83, 68, 0.06);
}

.claimable-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #a8f0d0 30%, #5cc9a0 100%);
  box-shadow: 0 0 6rpx 2rpx rgba(92, 201, 160, 0.6);
  animation: claimableDotBreathe 1.6s ease-in-out infinite;
  pointer-events: none;
  z-index: 5;
}

@keyframes claimableDotBreathe {
  0%, 100% {
    transform: scale(0.8);
    opacity: 0.6;
    box-shadow: 0 0 4rpx 2rpx rgba(92, 201, 160, 0.4);
  }
  50% {
    transform: scale(1.25);
    opacity: 1;
    box-shadow: 0 0 12rpx 4rpx rgba(92, 201, 160, 0.85);
  }
}

/* 固定导航层：高于游戏内容，低于新手引导遮罩 */
.game-nav-back {
  position: fixed;
  top: calc(20px + env(safe-area-inset-top, 0px));
  right: 20px;
  left: auto;
  z-index: 9000;
  pointer-events: auto;
}

.back-btn-icon {
  width: 22px;
  height: 22px;
}

.synthesis-area {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: var(--synthesis-bottom, 110px);
  min-height: 250px;
  overflow: visible;
  z-index: 45;
  pointer-events: none;
  touch-action: none;
}

.workbench-texture {
  position: absolute;
  top: var(--door-h, 260px);
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(ellipse 50% 45% at 50% 42%, rgba(255, 253, 247, 0.45) 0%, transparent 60%),
    linear-gradient(180deg, transparent 70%, rgba(255, 253, 247, 0.12) 100%);
  pointer-events: none;
}

.synthesis-area .game-item,
.synthesis-area .brewing-item,
.synthesis-area .trade-station {
  pointer-events: auto;
}

.inventory-area {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  box-sizing: border-box;
  height: var(--inv-h, 110px);
  padding: var(--inv-pad-top, 12px) calc(var(--inv-pad-x, 10px) + 6px) var(--inv-pad-bottom, 12px) var(--inv-pad-x, 10px);
  background: linear-gradient(180deg, rgba(255, 253, 247, 0.96) 0%, rgba(250, 245, 240, 0.98) 100%);
  box-shadow: 0 -8rpx 48rpx rgba(107, 83, 68, 0.05);
  border-top: 1px solid rgba(166, 124, 82, 0.08);
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  align-content: flex-start;
  gap: 8px;
  overflow-x: hidden;
  overflow-y: auto;
  z-index: 40;
  transition: height 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
  scrollbar-gutter: stable;
}

.inventory-area.golden-glow,
.inventory-area.golden-fade {
  overflow: visible;
  z-index: 80;
}

.inventory-area.rows-0,
.inventory-area.rows-1,
.inventory-area.rows-2,
.inventory-area.rows-3-plus {
  height: var(--inv-h, 110px);
}

.inventory-area.delete-hover {
  border-top-color: rgba(230, 58, 58, 0.95);
  box-shadow:
    0 -8rpx 48rpx rgba(107, 83, 68, 0.05),
    0 -4px 18px rgba(230, 58, 58, 0.42),
    inset 0 4px 16px rgba(230, 58, 58, 0.14);
}

/* H5 同款钻石计数与获得反馈，随物品栏高度一起移动。 */
.gem-display {
  position: fixed;
  right: 14px;
  bottom: calc(var(--inv-h, 110px) + 6px);
  z-index: 90;
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 4px 12px 4px 8px;
  box-sizing: border-box;
  background: rgba(255, 253, 247, 0.92);
  border: 1px solid rgba(232, 200, 115, 0.3);
  border-radius: 14px;
  box-shadow: 0 2px 8px rgba(107, 83, 68, 0.06);
  pointer-events: none;
  transition: bottom 0.35s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.gem-display-icon {
  width: 16px;
  height: 16px;
  flex: 0 0 16px;
}

.gem-count {
  min-width: 20px;
  color: #6b5344;
  font-size: 13px;
  font-weight: 500;
  line-height: 16px;
  text-align: center;
}

.gem-count.gem-bump {
  animation: gemBump 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes gemBump {
  0% { transform: scale(1); }
  40% { transform: scale(1.4); color: #e8c873; }
  100% { transform: scale(1); }
}

.gem-flyer {
  position: fixed;
  width: 20px;
  height: 20px;
  z-index: 3000;
  opacity: 1;
  transform: scale(1.3);
  pointer-events: none;
  transition-property: left, top, transform, opacity;
  transition-duration: 0.85s, 0.85s, 0.85s, 0.25s;
  transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1), cubic-bezier(0.4, 0, 0.2, 1), ease-out, ease-in;
}

.gem-flyer image {
  width: 100%;
  height: 100%;
}

.gem-flyer.flying {
  opacity: 0;
  transform: scale(0.7);
}

.gem-plus-label {
  position: fixed;
  right: 14px;
  bottom: calc(var(--inv-h, 110px) + 38px);
  z-index: 3001;
  width: 54px;
  color: #e8c873;
  font-size: 14px;
  font-weight: 700;
  text-align: center;
  text-shadow: 0 0 8px rgba(232, 200, 115, 0.7), 0 1px 3px rgba(0, 0, 0, 0.15);
  pointer-events: none;
  animation: gemPlusRise 1.3s ease-out forwards;
}

@keyframes gemPlusRise {
  0% { transform: translateY(0); opacity: 1; }
  55% { transform: translateY(-26px); opacity: 1; }
  100% { transform: translateY(-40px); opacity: 0; }
}

.inventory-delete-cue {
  position: fixed;
  left: 50%;
  bottom: calc(var(--inv-h, 110px) + 4px);
  width: 42px;
  height: 42px;
  transform: translateX(-50%) scale(0.84);
  opacity: 0;
  pointer-events: none;
  filter: drop-shadow(0 0 12px rgba(230, 58, 58, 0.78));
  transition: opacity 0.14s ease, transform 0.14s ease;
  z-index: 130;
}

.inventory-delete-cue.visible {
  opacity: 1;
  transform: translateX(-50%) scale(1);
  animation: deleteCuePulse 0.85s ease-in-out infinite;
}

.delete-bin {
  position: relative;
  width: 42px;
  height: 42px;
}

.delete-bin-lid {
  position: absolute;
  left: 9px;
  top: 7px;
  width: 24px;
  height: 6px;
  border-radius: 3px;
  background: #ff3d3d;
  box-shadow: 0 0 10px rgba(255, 61, 61, 0.8);
}

.delete-bin-lid::before {
  content: '';
  position: absolute;
  left: 8px;
  top: -4px;
  width: 8px;
  height: 4px;
  border-radius: 3px 3px 0 0;
  background: #ff6a6a;
}

.delete-bin-body {
  position: absolute;
  left: 11px;
  top: 16px;
  width: 20px;
  height: 22px;
  border-radius: 3px 3px 6px 6px;
  border: 3px solid #ff3d3d;
  box-sizing: border-box;
  background: rgba(230, 58, 58, 0.16);
  box-shadow: inset 0 0 8px rgba(255, 61, 61, 0.36), 0 0 12px rgba(255, 61, 61, 0.58);
}

.delete-bin-body::before,
.delete-bin-body::after {
  content: '';
  position: absolute;
  top: 4px;
  width: 2px;
  height: 12px;
  border-radius: 2px;
  background: #ff6a6a;
}

.delete-bin-body::before { left: 5px; }
.delete-bin-body::after { right: 5px; }

@keyframes deleteCuePulse {
  0%, 100% { filter: drop-shadow(0 0 8px rgba(230, 58, 58, 0.6)); }
  50% { filter: drop-shadow(0 0 18px rgba(255, 61, 61, 0.95)); }
}

/* 物品栏滚动条 — 对齐 H5 game-inventory.css（--brand-color-light = #F0D9A0） */
.inventory-area::-webkit-scrollbar {
  width: 0;
  height: 0;
}

.inventory-area::-webkit-scrollbar-track {
  background: transparent;
}

.inventory-area::-webkit-scrollbar-thumb {
  background: transparent;
  border-radius: 4px;
}

.multi-progress {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.multi-dot {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  background: rgba(107, 83, 68, 0.08);
  color: #A67C52;
}

.multi-dot.lit { background: rgba(232, 200, 115, 0.45); color: #6B5344; }

.trade-row {
  position: absolute;
  left: 0;
  right: 0;
  bottom: calc(var(--synthesis-bottom, 110px) + 8px);
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx;
  justify-content: center;
  z-index: 15;
}

.trade-btn {
  font-size: 22rpx;
  background: rgba(232, 200, 115, 0.25);
  color: #6B5344;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
}

.toast {
  position: fixed;
  top: 28vh;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(107, 83, 68, 0.92);
  color: #FFFDF7;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  z-index: 100;
  max-width: 80%;
  text-align: center;
}

.task-toast {
  position: fixed;
  top: calc(var(--safe-top, 24px) + 12px);
  left: 12px;
  min-width: 180px;
  max-width: 72%;
  box-sizing: border-box;
  background: #fff;
  color: #5CC9A0;
  border: 1px solid #5CC9A0;
  padding: 12px 16px;
  border-radius: 0;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.4;
  text-align: left;
  box-shadow: 0 4px 14px rgba(92, 201, 160, 0.16);
  z-index: 12000;
  animation: taskToastCard 2.2s ease both;
}

@keyframes taskToastCard {
  0% { opacity: 0; transform: translateX(-18px); }
  14%, 82% { opacity: 1; transform: translateX(0); }
  100% { opacity: 0; transform: translateX(-8px); }
}

.transition-banner {
  display: none;
}

.success-overlay, .ending-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 300;
}

.success-panel, .ending-panel {
  background: #FFFDF7;
  border-radius: 24rpx;
  padding: 48rpx;
  width: 80%;
  text-align: center;
}

.success-title { display: block; font-size: 36rpx; color: #6B5344; margin-bottom: 16rpx; }
.success-text { display: block; font-size: 28rpx; color: #A67C52; line-height: 1.6; margin-bottom: 32rpx; }
.ending-line { display: block; font-size: 32rpx; color: #FFFDF7; margin-bottom: 16rpx; }
.ending-overlay .ending-panel { background: rgba(20, 16, 14, 0.92); }
.ending-line.dim { opacity: 0.7; font-size: 28rpx; }
.ending-line.story { margin-top: 32rpx; font-size: 26rpx; color: rgba(232, 200, 115, 0.9); }

.success-btn {
  display: inline-block;
  background: #E8C873;
  color: #6B5344;
  border-radius: 999rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
}

/* ========== 温暖氛围背景 — 对齐 H5 .milk-fog-container + ::before ========== */
.milk-fog-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 0;
  background:
    radial-gradient(ellipse 70% 35% at 50% 15%, var(--chapter-glow, rgba(232, 200, 115, 0.2)) 0%, transparent 60%),
    radial-gradient(ellipse 40% 50% at 5% 50%, var(--chapter-glow, rgba(232, 200, 115, 0.2)) 0%, transparent 50%),
    radial-gradient(ellipse 40% 50% at 95% 50%, var(--chapter-glow, rgba(232, 200, 115, 0.2)) 0%, transparent 50%),
    var(--chapter-bg, #FDF8E8);
}

/* 边缘柔雾（单层，勿与 ::before 叠加重影） */
.milk-fog-edge-fade {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  background:
    linear-gradient(90deg, var(--chapter-edge-glow, rgba(232, 200, 115, 0.14)) 0%, transparent 10%, transparent 90%, var(--chapter-edge-glow, rgba(232, 200, 115, 0.14)) 100%),
    linear-gradient(180deg, transparent 0%, transparent 80%, var(--chapter-edge-glow, rgba(232, 200, 115, 0.14)) 100%);
}

.milk-fog-particle {
  position: absolute;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 253, 247, 0.5) 0%, transparent 70%);
  animation: milkFogFloat ease-in-out infinite;
  z-index: 1;
}

@keyframes milkFogFloat {
  0%, 100% {
    transform: translateY(0) translateX(0) scale(1);
    opacity: 0.06;
  }
  25% {
    transform: translateY(-6px) translateX(4px) scale(1.03);
    opacity: 0.1;
  }
  50% {
    transform: translateY(-10px) translateX(0) scale(1.06);
    opacity: 0.12;
  }
  75% {
    transform: translateY(-5px) translateX(-4px) scale(1.02);
    opacity: 0.08;
  }
}

.bg-decor-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
}

.grass-clump {
  position: absolute;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  width: 42px;
  height: 36px;
  transform: translate(-50%, -50%);
}

.grass-blade {
  display: inline-block;
  vertical-align: bottom;
  border-radius: 1px;
  transform-origin: center bottom;
  transform: rotate(var(--base-rot, 0deg));
  animation: windSway ease-in-out infinite;
}

@keyframes windSway {
  0%, 100% { transform: rotate(var(--base-rot, 0deg)); }
  50% { transform: rotate(calc(var(--base-rot, 0deg) + var(--sway, 6deg))); }
}

.bg-dust {
  position: absolute;
  border-radius: 50%;
  background: rgba(200, 180, 140, 0.5);
  animation: dustDrift ease-out forwards;
}

@keyframes dustDrift {
  0%   { transform: translate(0, 0); opacity: 0; }
  15%  { opacity: 0.55; }
  85%  { opacity: 0.4; }
  100% { transform: translate(var(--dx, 80px), var(--dy, -40px)); opacity: 0; }
}
