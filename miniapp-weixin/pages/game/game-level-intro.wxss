/* 关卡开场介绍 + 过关文案 — 对齐 H5 game-level-intro.css */

.level-intro-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 11000;   /* above .game-nav-back (10001) */
  pointer-events: none;
  transition: background 0.8s ease;
}

.level-intro-overlay.visible {
  background: rgba(0, 0, 0, 0.75);
  pointer-events: auto;
}

.level-intro-overlay.fade-out {
  background: rgba(0, 0, 0, 0);
  pointer-events: none;
}

.level-intro-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 82%;
  max-width: 400px;
  text-align: center;
}

.intro-level-name {
  font-size: 30px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6px;
  text-shadow: 0 0 12px rgba(255, 255, 255, 0.7), 0 0 30px rgba(255, 255, 255, 0.3);
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.level-intro-overlay.visible .intro-level-name {
  opacity: 1;
  transform: translateY(0);
}

.intro-separator {
  width: 50px;
  height: 1px;
  background: rgba(255, 255, 255, 0.5);
  margin: 16px 0;
  opacity: 0;
  transition: opacity 0.6s ease 0.3s;
}

.level-intro-overlay.visible .intro-separator {
  opacity: 1;
}

.intro-target {
  font-size: 15px;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2px;
  text-shadow: 0 0 8px rgba(255, 255, 255, 0.4);
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.5s ease 0.4s, transform 0.5s ease 0.4s;
}

.level-intro-overlay.visible .intro-target {
  opacity: 1;
  transform: translateY(0);
}

.intro-desc {
  font-size: 14px;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 1px;
  line-height: 1.7;
  margin-top: 12px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.5s ease 0.6s, transform 0.5s ease 0.6s;
}

.level-intro-overlay.visible .intro-desc {
  opacity: 1;
  transform: translateY(0);
}

.intro-tip {
  margin-top: 14px;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.58);
  letter-spacing: 1px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.5s ease 0.8s, transform 0.5s ease 0.8s;
}

.level-intro-overlay.visible .intro-tip {
  opacity: 1;
  transform: translateY(0);
}

.level-intro-overlay.fade-out .intro-level-name,
.level-intro-overlay.fade-out .intro-separator,
.level-intro-overlay.fade-out .intro-target,
.level-intro-overlay.fade-out .intro-desc,
.level-intro-overlay.fade-out .intro-tip {
  opacity: 0;
  transform: translateY(-6px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

/* 105 阶段结算 — 对齐 H5 game-level-intro.css .settlement-* */
.settlement-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 5500;
  pointer-events: none;
  transition: background 1s ease;
}

.settlement-overlay.visible {
  background: rgba(0, 0, 0, 0.82);
  pointer-events: auto;
}

.settlement-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 85%;
  max-width: 360px;
  text-align: center;
}

.settlement-title {
  font-size: 24px;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6px;
  text-shadow: 0 0 12px rgba(255, 255, 255, 0.6);
  opacity: 0;
  transform: translateY(12px);
  transition: opacity 0.7s ease 0.3s, transform 0.7s ease 0.3s;
}

.settlement-overlay.visible .settlement-title {
  opacity: 1;
  transform: translateY(0);
}

.settlement-sep {
  width: 60px;
  height: 1px;
  background: rgba(255, 255, 255, 0.4);
  margin: 20px 0;
  opacity: 0;
  transition: opacity 0.6s ease 0.6s;
}

.settlement-overlay.visible .settlement-sep {
  opacity: 1;
}

.settlement-encouragement {
  max-width: 320px;
  color: rgba(255, 255, 255, 0.84);
  font-size: 17px;
  line-height: 1.8;
  letter-spacing: 1px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.6s ease 0.75s, transform 0.6s ease 0.75s;
}

.settlement-overlay.visible .settlement-encouragement {
  opacity: 1;
  transform: translateY(0);
}

.settlement-progress {
  width: 100%;
  margin-top: 28px;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 10px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.6s ease 1s, transform 0.6s ease 1s;
}

.settlement-overlay.visible .settlement-progress {
  opacity: 1;
  transform: translateY(0);
}

.settlement-progress-label {
  color: rgba(255, 255, 255, 0.62);
  font-size: 14px;
  letter-spacing: 2px;
}

.settlement-progress-value {
  color: #ffe2a7;
  font-size: 42px;
  font-weight: 700;
  line-height: 1;
  text-shadow: 0 0 18px rgba(255, 213, 130, 0.35);
}

.settlement-progress-track {
  width: 100%;
  height: 6px;
  border-radius: 999px;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.16);
}

.settlement-progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #d7aa70 0%, #ffe2a7 100%);
  box-shadow: 0 0 16px rgba(255, 221, 158, 0.45);
}

.settlement-message {
  margin-top: 28px;
  font-size: 14px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.66);
  letter-spacing: 2px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.6s ease 1.3s, transform 0.6s ease 1.3s;
}

.settlement-message text {
  display: block;
}

.settlement-overlay.visible .settlement-message {
  opacity: 1;
  transform: translateY(0);
}

.settlement-buttons {
  display: flex;
  gap: 20px;
  margin-top: 36px;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.6s ease 1.65s, transform 0.6s ease 1.65s;
}

.settlement-overlay.visible .settlement-buttons {
  opacity: 1;
  transform: translateY(0);
}

.settlement-btn {
  padding: 10px 22px;
  border-radius: 22px;
  font-size: 14px;
  letter-spacing: 2px;
}

.settlement-btn-exit {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.35);
  color: rgba(255, 255, 255, 0.75);
}

.settlement-btn-continue {
  background: rgba(232, 200, 115, 0.9);
  border: 1px solid rgba(232, 200, 115, 0.5);
  color: #4a3828;
  font-weight: 600;
}
