/* 章内转场 — 对齐 H5 game-inventory.css 金光 / bubble-pop / item-pop-in */

.inventory-area.golden-glow {
  border: 2px solid rgba(255, 200, 80, 0);
  animation: inventoryGoldenGlow 0.5s ease-out forwards;
}

@keyframes inventoryGoldenGlow {
  0% {
    box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.05);
    border-color: rgba(255, 200, 80, 0);
  }
  100% {
    box-shadow:
      0 0 25px rgba(255, 200, 80, 0.5),
      0 0 50px rgba(255, 180, 50, 0.35),
      0 0 80px rgba(255, 160, 30, 0.2),
      inset 0 0 20px rgba(255, 200, 80, 0.25),
      0 -4px 30px rgba(0, 0, 0, 0.05);
    border-color: rgba(255, 200, 80, 0.6);
  }
}

.inventory-area.golden-fade {
  animation: inventoryGoldenFade 0.6s ease-out forwards;
}

@keyframes inventoryGoldenFade {
  0% {
    box-shadow:
      0 0 25px rgba(255, 200, 80, 0.5),
      0 0 50px rgba(255, 180, 50, 0.35),
      inset 0 0 20px rgba(255, 200, 80, 0.25);
    border-color: rgba(255, 200, 80, 0.6);
  }
  100% {
    box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.05);
    border-color: transparent;
  }
}

.inventory-item-slot.pop-done {
  visibility: hidden;
  pointer-events: none;
}

/* 缩放动画挂在外壳上，槽位尺寸不变 */
.item-pop-body {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  transform-origin: center center;
}

/* 出现前预占位，避免 scale(1) 闪一帧 */
.item-pop-body.pop-hold {
  opacity: 0;
  transform: scale(0);
  pointer-events: none;
}

.item-pop-body .game-item.in-inventory {
  transition: none !important;
}

.item-pop-body.bubble-pop,
.item-pop-body.item-pop-in {
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.item-pop-body.golden-outline .game-item.in-inventory {
  animation: itemGoldenOutline 0.4s ease-out forwards;
}

@keyframes itemGoldenOutline {
  0% { box-shadow: 0 6px 16px rgba(139, 115, 85, 0.15); }
  100% {
    box-shadow:
      0 0 15px rgba(255, 200, 80, 0.7),
      0 0 30px rgba(255, 180, 50, 0.5),
      0 0 45px rgba(255, 160, 30, 0.3),
      inset 0 0 10px rgba(255, 200, 80, 0.3);
  }
}

.item-pop-body.bubble-pop {
  animation: bubblePop 1.6s ease-out forwards;
}

@keyframes bubblePop {
  0% { transform: scale(1); opacity: 1; }
  35% { transform: scale(1.4); opacity: 1; }
  60% { transform: scale(1.2); opacity: 0.85; }
  100% { transform: scale(0); opacity: 0; }
}

.item-pop-body.item-pop-in {
  animation: itemPopInTransition 1.9s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
}

@keyframes itemPopInTransition {
  0% { transform: scale(0); opacity: 0; }
  30% { transform: scale(1.3); opacity: 1; }
  50% { transform: scale(0.85); opacity: 1; }
  70% { transform: scale(1.1); opacity: 1; }
  85% { transform: scale(0.95); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

.item-pop-glow {
  position: absolute;
  top: -8px;
  left: -8px;
  right: -8px;
  bottom: -8px;
  border-radius: 22px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.65) 0%, transparent 65%);
  pointer-events: none;
  animation: popGlow 1.9s ease-out forwards;
  animation-delay: 0.12s;
  z-index: -1;
}

@keyframes popGlow {
  0% { opacity: 0; transform: scale(0.6); }
  25% { opacity: 1; transform: scale(1); }
  60% { opacity: 0.6; transform: scale(1.2); }
  100% { opacity: 0; transform: scale(1.4); }
}

.game-item.shrinking {
  transition: transform 0.35s ease-in, opacity 0.35s ease-in !important;
  transform: scale(0) !important;
  opacity: 0 !important;
}

.trade-row.trade-hidden {
  opacity: 0;
  transform: scale(0);
  pointer-events: none;
  transition: transform 0.4s ease-in, opacity 0.4s ease-in;
}

.level-target-display.target-hidden {
  transform: scale(0);
  opacity: 0;
  transition: transform 0.4s ease-in, opacity 0.4s ease-in;
}

.level-target-display.target-pop-in {
  animation: targetPopIn 0.5s cubic-bezier(0, 0, 0.2, 1.2) forwards;
}

@keyframes targetPopIn {
  from { transform: scale(0); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.level-target-display.target-flash .target-name {
  animation: goldGlowScale 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes goldGlowScale {
  0% { transform: scale(1); color: #E8C873; }
  30% { transform: scale(1.3); color: #FFD700; text-shadow: 0 0 20px #FFD700, 0 0 40px rgba(255, 215, 0, 0.5); }
  100% { transform: scale(1); color: #E8C873; }
}

.foam-burst {
  position: fixed;
  pointer-events: none;
  z-index: 1000;
  transform: translate(-50%, -50%);
}

.foam-particle {
  position: absolute;
  left: 0;
  top: 0;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%,
    rgba(255, 255, 255, 0.98) 0%,
    rgba(250, 250, 255, 0.8) 35%,
    rgba(220, 235, 255, 0.5) 60%,
    transparent 100%);
  box-shadow:
    inset 0 -2px 4px rgba(255, 255, 255, 0.9),
    0 0 8px rgba(200, 220, 255, 0.6);
  animation: foamBurst 2.2s ease-out forwards;
}

.foam-particle.large {
  box-shadow:
    inset 0 -3px 6px rgba(255, 255, 255, 0.95),
    0 0 12px rgba(200, 220, 255, 0.7);
}

@keyframes foamBurst {
  0% { transform: translate(0, 0) scale(0); opacity: 1; }
  15% { transform: translate(calc(var(--foam-x) * 0.15), calc(var(--foam-y) * 0.15)) scale(1.4); opacity: 1; }
  35% { transform: translate(calc(var(--foam-x) * 0.45), calc(var(--foam-y) * 0.45)) scale(1.1); opacity: 0.95; }
  100% { transform: translate(var(--foam-x), calc(var(--foam-y) + 35px)) scale(0.1); opacity: 0; }
}
