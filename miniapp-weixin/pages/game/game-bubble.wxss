/* 门的对话气泡 — 对齐 H5 css/game/game-synthesis.css */

.door-bubble {
  position: fixed;
  z-index: 50;
  pointer-events: none;
  padding: 8px 14px;
  border-radius: 12px;
  background: rgba(58, 42, 12, 0.6);
  border: 1.5px solid rgba(255, 220, 100, 0.6);
  box-shadow:
    0 0 12px rgba(255, 220, 100, 0.2),
    0 0 28px rgba(255, 220, 100, 0.1),
    0 0 48px rgba(201, 164, 60, 0.06);
  opacity: 0;
  transform: scale(0.9) translateY(6px);
  box-sizing: border-box;
}

.door-bubble.visible {
  animation: doorBubbleIn 0.6s cubic-bezier(0.25, 0.1, 0.25, 1) both;
}

.door-bubble.fade-out {
  animation: doorBubbleFadeOut 0.8s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
}

.door-bubble-text {
  display: block;
  color: #FFE278;
  font-size: 13px;
  font-weight: 500;
  line-height: 1.65;
  letter-spacing: 0.8px;
  text-shadow:
    0 0 10px rgba(255, 226, 120, 0.55),
    0 0 24px rgba(255, 220, 100, 0.3),
    0 0 48px rgba(201, 164, 60, 0.15);
}

.door-bubble-tail {
  position: absolute;
  top: 50%;
  width: 0;
  height: 0;
  border-top: 7px solid transparent;
  border-bottom: 7px solid transparent;
  margin-top: -7px;
}

.door-bubble.tail-right .door-bubble-tail {
  right: -9px;
  border-left: 9px solid rgba(58, 42, 12, 0.6);
  filter: drop-shadow(2px 0 4px rgba(255, 220, 100, 0.15));
}

.door-bubble.tail-left .door-bubble-tail {
  left: -9px;
  border-right: 9px solid rgba(58, 42, 12, 0.6);
  filter: drop-shadow(-2px 0 4px rgba(255, 220, 100, 0.15));
}

@keyframes doorBubbleIn {
  0%   { opacity: 0; transform: scale(0.9) translateY(6px); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes doorBubbleFadeOut {
  0%   { opacity: 1; transform: scale(1) translateY(0); }
  100% { opacity: 0; transform: scale(0.92) translateY(-8px); }
}
