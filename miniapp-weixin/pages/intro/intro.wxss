.intro-screen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #000;
  z-index: 1000;
  overflow: hidden;
  transition: background-color 5s ease-out;
}

.intro-screen.warm-transition {
  background-color: #F5E6E0;
}

.intro-flash {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #fff;
  z-index: 100;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.intro-flash.flash {
  opacity: 1;
}

.intro-flash.fade-out {
  opacity: 0;
  transition: opacity 1.5s ease;
}

.canvas-stack {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
  pointer-events: none;
}

.intro-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 5;
  pointer-events: none;
}

.ambience-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.intro-dot-wrap {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20px;
  height: 20px;
  margin-left: -10px;
  margin-top: -10px;
  z-index: 200;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.intro-dot-wrap.visible {
  opacity: 1;
  pointer-events: auto;
}

.intro-dot-core {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 0 30px rgba(255, 255, 255, 0.6);
  animation: dotBreath 2s ease-in-out infinite;
}

/* 光波扩散 — 对齐 H5 #intro-dot ::before/::after */
.dot-pulse-wave {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  border: 2px solid rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  transform: translate(-50%, -50%) scale(1);
  opacity: 0;
  pointer-events: none;
  box-sizing: border-box;
}

.intro-dot-wrap.visible .dot-pulse-wave {
  animation: dotPulseWave 2s ease-out infinite;
}

.intro-dot-wrap.visible .wave-b {
  animation-delay: 1s;
}

@keyframes dotPulseWave {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.8;
    border-width: 2px;
  }
  100% {
    transform: translate(-50%, -50%) scale(3);
    opacity: 0;
    border-width: 1px;
  }
}

@keyframes dotBreath {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 0 15px rgba(255, 255, 255, 0.4);
  }
  50% {
    transform: scale(1.3);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.7);
  }
}

.intro-door {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 120px;
  height: 180px;
  margin-left: -60px;
  margin-top: -110px;
  z-index: 10;
  opacity: 0;
  transition: opacity 0.8s ease;
  background: transparent;
}

.door-frame {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 3px solid rgba(150, 150, 150, 0.6);
  border-radius: 60px 60px 0 0;
  box-sizing: border-box;
  background-color: #000;
}

.door-inner {
  position: absolute;
  left: 8px;
  right: 8px;
  top: 8px;
  bottom: 0;
  background-color: #000;
  border-radius: 52px 52px 0 0;
  overflow: hidden;
  pointer-events: none;
  z-index: 0;
}

.door-glow {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 50% 40%, rgba(232, 200, 115, 0.3) 0%, rgba(200, 170, 80, 0.1) 50%, rgba(0, 0, 0, 0) 80%);
  opacity: 0;
  z-index: 1;
  pointer-events: none;
}

.intro-door.breathing .door-glow {
  animation: doorBreathGlow 2s ease-in-out infinite;
}

@keyframes doorBreathGlow {
  0%, 100% { opacity: 0.3; transform: scale(0.95); }
  50% { opacity: 0.7; transform: scale(1.02); }
}

.intro-door.breathing .door-frame {
  animation: doorFrameBreath 2s ease-in-out infinite;
}

@keyframes doorFrameBreath {
  0%, 100% {
    border-color: rgba(150, 150, 150, 0.5);
    box-shadow: 0 0 10px rgba(232, 200, 115, 0.1);
  }
  50% {
    border-color: rgba(200, 185, 150, 0.7);
    box-shadow: 0 0 25px rgba(232, 200, 115, 0.25);
  }
}

.intro-door.active .door-glow {
  opacity: 0.8;
  animation: doorActiveGlow 1s ease-in-out infinite;
}

@keyframes doorActiveGlow {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.intro-door.active .door-frame {
  border-color: rgba(232, 200, 115, 0.7);
  box-shadow: 0 0 30px rgba(232, 200, 115, 0.4);
}

.intro-door.hover .door-glow { opacity: 1; }

.intro-door.hover .door-frame {
  border-color: rgba(255, 220, 100, 0.9);
  box-shadow: 0 0 40px rgba(255, 220, 100, 0.5);
}

.intro-door.absorbing .door-glow {
  animation: doorAbsorb 0.6s ease-in forwards;
}

@keyframes doorAbsorb {
  0% { opacity: 0.8; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
  100% { opacity: 0.3; transform: scale(0.9); }
}

.intro-door.releasing .door-glow {
  animation: doorRelease 1s ease-out forwards;
}

@keyframes doorRelease {
  0% { opacity: 0.3; transform: scale(0.9); }
  30% { opacity: 1; transform: scale(1.3); }
  100% { opacity: 0.5; transform: scale(1); }
}

.intro-inventory {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  height: 180px;
  background-color: rgba(30, 30, 35, 0.85);
  z-index: 20;
  opacity: 0;
  transform: translateY(100%);
  transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.8s ease;
  box-shadow: 0 -5px 30px rgba(0, 0, 0, 0.5);
  pointer-events: none;
}

.intro-inventory.visible {
  opacity: 1;
  transform: translateY(0);
}

/* 透明触摸层：承接物品拖拽（门/物品已改为 canvas 绘制） */
.intro-touch-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 25;
  background: transparent;
}

.intro-item {
  position: absolute;
  border: 2px solid rgba(100, 100, 110, 0.6);
  border-radius: 50%;
  opacity: 0;
  transform: scale(0.5);
  transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  box-sizing: border-box;
  pointer-events: auto;
}

/* 实心填充层 — 避免 canvas 上 view 背景透底 */
.intro-item-fill {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-color: rgb(40, 40, 45);
  z-index: 0;
}

.intro-item.visible {
  opacity: 1;
  transform: scale(1);
}

.intro-item.dragging {
  z-index: 100;
}

.intro-item.golden {
  border-color: rgba(255, 200, 50, 0.8);
  box-shadow: 0 0 20px rgba(255, 200, 50, 0.4);
}

.intro-item.golden .intro-item-fill {
  background-color: rgb(42, 40, 36);
}

.intro-item.golden.golden-border-only {
  box-shadow: none;
  border-color: rgba(255, 210, 80, 0.95);
}

.intro-item.synthesis-result {
  border-color: rgba(232, 200, 115, 0.6);
  box-shadow: 0 0 25px rgba(232, 200, 115, 0.3);
}

.intro-item.synthesis-result .intro-item-fill {
  background-color: rgb(50, 50, 55);
}

.item-icon {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  font-size: 32px;
  line-height: 44px;
  color: #fff;
}

.item-name {
  position: relative;
  z-index: 1;
  display: block;
  text-align: center;
  font-size: 11px;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 2px;
}

.synthesis-flash {
  position: absolute;
  width: 200px;
  height: 200px;
  margin-left: -100px;
  margin-top: -100px;
  background: radial-gradient(circle, rgba(255, 255, 255, 1) 0%, rgba(255, 235, 180, 0.8) 40%, rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
  z-index: 50;
  animation: flashBurst 0.6s cubic-bezier(0.1, 0.9, 0.2, 1) forwards;
}

@keyframes flashBurst {
  0% { transform: scale(0.1); opacity: 1; }
  10% { transform: scale(1.5); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

.intro-narrative {
  position: absolute;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18px;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 3px;
  z-index: 30;
  opacity: 0;
  transition: opacity 0.6s ease;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.7), 0 0 25px rgba(255, 255, 255, 0.3);
  white-space: nowrap;
}

.intro-narrative.visible {
  opacity: 1;
}

.story-container {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  z-index: 50;
  width: 80vw;
}

.story-text {
  display: block;
  font-size: 24px;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: 4px;
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 1s ease, transform 1s ease;
  text-shadow: 0 0 10px rgba(255, 255, 255, 0.6), 0 0 25px rgba(255, 255, 255, 0.25);
  white-space: pre-wrap;
}

.story-text.show {
  opacity: 1;
  transform: scale(1);
}

.story-text.goal-text {
  color: #fff;
  font-size: 22px;
  text-shadow: 0 0 12px rgba(255, 255, 255, 0.7), 0 0 30px rgba(255, 255, 255, 0.35);
}

.skip-btn {
  position: fixed;
  right: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: rgba(255, 253, 247, 0.85);
  background: rgba(0, 0, 0, 0.35);
  border-radius: 999rpx;
  z-index: 300;
}

@media (max-width: 450px) and (max-height: 950px) {
  .story-text { font-size: 14px; letter-spacing: 2px; }
  .story-text.goal-text { font-size: 14px; }
  .intro-narrative { font-size: 19px; letter-spacing: 2.5px; }
}

/* ═══════════════════════════════════════════════
   主菜单覆盖层（粒子聚字后内嵌，对齐 H5 showMainScreen）
   ══════════════════════════════════════════════ */

/* CSS 变量（对齐 index.wxss :root） */
.intro-main-ui {
  --dawn-pink: #F5E6E0;
  --rice-wine-gold: #E8C873;
  --dawn-gold: #F0D9A0;
  --caramel-brown: #A67C52;
  --old-wood: #6B5344;
  --milk-foam: #FFFDF7;
  --moss-green: #7BA37B;

  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.8s ease;
}

.intro-main-ui.menu-visible {
  opacity: 1;
  pointer-events: auto;
}

.main-menu-container {
  position: relative;
  width: 90%;
  max-width: 320px;
  margin-top: 10vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
  pointer-events: auto;
  transform: scale(0.9);
  transform-origin: top center;
}

.main-menu-block {
  width: 100%;
  display: flex;
  flex-direction: column;
  border-top: 1px solid rgba(166, 124, 82, 0.38);
  border-bottom: 1px solid rgba(166, 124, 82, 0.38);
}

.main-menu-block > view {
  width: 100%;
  box-sizing: border-box;
  padding: 20px 4px;
  border-bottom: 1px solid rgba(166, 124, 82, 0.12);
}

.main-menu-block > view:last-child {
  border-bottom: none;
}

.main-btn {
  display: block;
  width: 100%;
  text-align: center;
  background: transparent;
  box-sizing: border-box;
}

.main-btn.primary {
  font-size: 17px;
  font-weight: 600;
  letter-spacing: 8px;
  color: var(--old-wood);
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", "PingFang SC", serif;
}

.main-btn.secondary {
  font-size: 13px;
  letter-spacing: 5px;
  color: var(--caramel-brown);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.menu-row-flash {
  animation: menuRowFlashPrimary 0.5s ease-out;
  color: var(--rice-wine-gold) !important;
}

.menu-row-flash-secondary {
  animation: menuRowFlashSecondary 0.5s ease-out;
  color: var(--rice-wine-gold) !important;
}

@keyframes menuRowFlashPrimary {
  0% { background: rgba(232, 200, 115, 0); }
  35% { background: rgba(232, 200, 115, 0.22); }
  100% { background: rgba(232, 200, 115, 0); }
}

@keyframes menuRowFlashSecondary {
  0% { background: rgba(232, 200, 115, 0); color: var(--caramel-brown); }
  35% { background: rgba(232, 200, 115, 0.22); color: var(--rice-wine-gold); }
  100% { background: rgba(232, 200, 115, 0); color: var(--caramel-brown); }
}

.main-progress-row {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  box-sizing: border-box;
}

.progress-label {
  font-size: 12px;
  color: var(--caramel-brown);
  min-width: 60px;
  letter-spacing: 2px;
  flex-shrink: 0;
}

.progress-bar {
  flex: 1;
  height: 3px;
  background: rgba(166, 124, 82, 0.15);
  border-radius: 2px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--rice-wine-gold) 0%, var(--dawn-gold) 100%);
  border-radius: 2px;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 11px;
  color: var(--caramel-brown);
  min-width: 40px;
  text-align: right;
  letter-spacing: 1px;
  flex-shrink: 0;
}

.main-footer-row {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin-top: 12px;
}

.main-footer-side {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.main-footer-side-left {
  justify-content: flex-end;
  padding-right: 8px;
}

.main-footer-side-right {
  justify-content: flex-start;
  padding-left: 8px;
}

.main-link-btn-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.main-link-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: var(--caramel-brown);
  font-size: 11px;
  letter-spacing: 2px;
  padding: 2px 4px 4px;
  opacity: 0.65;
  line-height: 1;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  white-space: nowrap;
  border-bottom: 1px solid rgba(166, 124, 82, 0.35);
}

.link-btn-flash {
  opacity: 1 !important;
  color: var(--rice-wine-gold) !important;
  border-bottom-color: var(--rice-wine-gold) !important;
  animation: linkBtnFlash 0.45s ease-out;
}

@keyframes linkBtnFlash {
  0% { opacity: 0.65; border-bottom-color: rgba(166, 124, 82, 0.35); color: var(--caramel-brown); }
  35% { opacity: 1; border-bottom-color: var(--rice-wine-gold); color: var(--rice-wine-gold); }
  100% { opacity: 0.65; border-bottom-color: rgba(166, 124, 82, 0.35); color: var(--caramel-brown); }
}

.main-footer-divider {
  flex-shrink: 0;
  width: 12px;
  text-align: center;
  line-height: 1;
  color: var(--caramel-brown);
  font-size: 12px;
  opacity: 0.4;
}

.footer-claimable-dot {
  top: -2px;
  right: -4px;
}

.claimable-dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #a8f0d0 30%, #5cc9a0 100%);
  box-shadow: 0 0 6rpx 2rpx rgba(92, 201, 160, 0.6);
  animation: claimableDotBreathe 1.6s ease-in-out infinite;
  pointer-events: none;
  z-index: 5;
}

@keyframes claimableDotBreathe {
  0%, 100% {
    transform: scale(0.8);
    opacity: 0.6;
    box-shadow: 0 0 4rpx 2rpx rgba(92, 201, 160, 0.4);
  }
  50% {
    transform: scale(1.25);
    opacity: 1;
    box-shadow: 0 0 12rpx 4rpx rgba(92, 201, 160, 0.85);
  }
}

/* ── 面板 ── */

.panel-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(107, 83, 68, 0.4);
  backdrop-filter: blur(8px);
  z-index: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
}

.panel-overlay.visible {
  opacity: 1;
  visibility: visible;
}

.panel {
  width: 90%;
  max-width: 450px;
  max-height: 85vh;
  background: var(--milk-foam);
  border: 1px solid rgba(166, 124, 82, 0.1);
  border-radius: 16px;
  padding: 24px;
  box-shadow: 0 20px 60px rgba(107, 83, 68, 0.15), 0 4px 16px rgba(107, 83, 68, 0.08);
  overflow-y: auto;
  position: relative;
  box-sizing: border-box;
}

.panel-close {
  position: absolute;
  top: 16px;
  right: 16px;
  width: 32px;
  height: 32px;
  border: none;
  background: rgba(166, 124, 82, 0.08);
  border-radius: 50%;
  font-size: 16px;
  color: var(--caramel-brown);
  padding: 0;
  line-height: 32px;
}

.panel-close::after { border: none; }

.panel-title {
  font-size: 17px;
  font-weight: 400;
  color: var(--old-wood);
  text-align: center;
  margin-bottom: 20px;
  letter-spacing: 4px;
  font-family: "Source Han Serif SC", "Noto Serif SC", "Songti SC", "PingFang SC", serif;
}

/* ── 设置面板 ── */

.settings-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.settings-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 0;
}

.settings-label {
  font-size: 13px;
  color: var(--caramel-brown);
  min-width: 70px;
  flex-shrink: 0;
}

.volume-slider { flex: 1; }

.volume-value {
  font-size: 12px;
  color: var(--caramel-brown);
  min-width: 40px;
  text-align: right;
}

.settings-divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--caramel-brown), transparent);
  opacity: 0.15;
  margin: 8px 0;
}

.settings-info {
  text-align: center;
  padding: 16px 0;
  display: flex;
  flex-direction: column;
  gap: 4px;
  font-size: 12px;
  color: var(--caramel-brown);
}

.settings-info .info-sub {
  font-size: 11px;
  opacity: 0.7;
}

/* ── 任务面板 ── */

.tasks-panel { max-width: 480px; }

.tasks-list {
  display: flex;
  flex-direction: column;
}

.task-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 0;
  border-bottom: 1px solid rgba(166, 124, 82, 0.08);
}

.task-row:last-child { border-bottom: none; }
.task-row.task-done.task-claimed { opacity: 0.5; }

.task-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.task-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.task-name {
  font-size: 13px;
  color: var(--old-wood);
  font-weight: 500;
  letter-spacing: 1px;
}

.task-check { color: var(--moss-green); }

.task-desc {
  font-size: 11px;
  color: var(--caramel-brown);
  opacity: 0.7;
}

.task-progress-bar {
  width: 100%;
  height: 3px;
  background: rgba(166, 124, 82, 0.12);
  border-radius: 2px;
  overflow: hidden;
}

.task-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--rice-wine-gold), var(--dawn-gold));
  border-radius: 2px;
}

.task-progress-text {
  font-size: 10px;
  color: var(--caramel-brown);
  opacity: 0.6;
  letter-spacing: 1px;
}

.task-reward {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  position: relative;
}

.task-reward-label {
  font-size: 10px;
  color: var(--caramel-brown);
  opacity: 0.5;
  letter-spacing: 1px;
}

.task-reward-value {
  font-size: 11px;
  color: var(--rice-wine-gold);
  letter-spacing: 1px;
}

.task-reward.task-claimable .task-reward-label {
  color: var(--rice-wine-gold);
  opacity: 1;
  font-weight: 600;
}

/* ── 响应式 ── */

@media (max-width: 360px) {
  .main-menu-container { margin-top: 26vh; }
  .main-btn.primary { font-size: 16px; letter-spacing: 6px; }
  .main-btn.secondary { letter-spacing: 4px; }
  .progress-label { min-width: 50px; }
}

@media (min-width: 361px) and (max-width: 414px) {
  .main-menu-container { margin-top: 24vh; }
}

@media (min-width: 768px) {
  .main-menu-container { max-width: 380px; margin-top: 19vh; }
}
