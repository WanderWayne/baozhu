<view
  class="intro-screen {{warmTransition ? 'warm-transition' : ''}} {{settingsVisible || tasksVisible ? 'panel-open' : ''}}"
  style="background-color: {{screenBg}};"
>
  <view class="canvas-stack">
    <canvas
      type="2d"
      id="ambience-canvas"
      class="ambience-canvas"
      style="opacity: {{ambienceOpacity}};"
    ></canvas>

    <canvas
      type="2d"
      id="intro-canvas"
      class="intro-canvas"
    ></canvas>
  </view>

  <view class="intro-flash {{flashClass}}"></view>

  <!-- 闂備緡鍋勭换鎴澪ｉ幋鐘冲枂闁挎棁濮ら崵瀣倶閻愭彃浜扮紒杈╂珱anvas 婵炴垶鎸搁幖顐ゆ暜椤愶附鍋ㄩ柣鏃堫棑濠€鎾煥濞戞ɑ婀伴悗姘儔楠炲繘骞嬮幒鏃傛婵炲濮存晶搴ｅ垝閳ユ剚娼伴柕鍫濇噺缂嶅繘鏌″鍛悙闁规枼鍓濈粙?-->
  <view
    class="intro-touch-layer"
    catchtouchstart="onItemTouchStart"
    catchtouchmove="onItemTouchMove"
    catchtouchend="onItemTouchEnd"
    catchtouchcancel="onItemTouchEnd"
  ></view>

  <view
    class="intro-dot-wrap {{dotVisible ? 'visible' : ''}}"
    style="opacity: {{dotOpacity}};"
    bindtap="onDotTap"
  >
    <view class="dot-pulse-wave wave-a"></view>
    <view class="dot-pulse-wave wave-b"></view>
    <view class="intro-dot-core"></view>
  </view>
  <view wx:if="{{!menuMode}}" class="intro-version">{{buildVersion}}</view>
<view class="intro-narrative {{narrativeVisible ? 'visible' : ''}}">{{narrativeText}}</view>

  <view class="story-container" wx:if="{{storyVisible}}">
    <text class="story-text {{storyTextGoal ? 'goal-text' : ''}} {{storyTextVisible ? 'show' : ''}}">{{storyText}}</text>
  </view>

  <!-- 婵炴垶鎸诲Σ鎺曘亹瀹ュ纭€闁哄洠妲呭ú顒勬煟閳哄倻澧柣顏冨嵆閺佸秴顫濇潏鈺冨帥闁诲孩绋掗崝妯荤濞戞埃鍋撳☉娆樻當闁诡喗顨婇幆鍕偓娑櫭径宥夋煕閿斿搫濡芥い鎺撶箖閵囧嫰妫冨☉姘秾缂備讲鍋撻柣姘嚟缁€澶娾槈閹惧磭啸闁绘埊闄勫?index -->
  <view wx:if="{{menuMode}}" class="intro-main-ui {{menuVisible ? 'menu-visible' : ''}}">
    <view class="main-menu-container">
      <view class="main-menu-block">
        <view class="main-btn primary" hover-class="menu-row-flash" bindtap="onContinue">开始游戏</view>

        <view class="main-progress-row" hover-class="menu-row-flash" bindtap="onCodex">
          <text class="progress-label">宝珠图谱</text>
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{codexPercent}}%;"></view>
          </view>
          <text class="progress-text">{{codexText}}</text>
        </view>

        <view class="main-progress-row" hover-class="menu-row-flash" bindtap="onGallery">
          <text class="progress-label">记忆碎片</text>
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{fragmentPercent}}%;"></view>
          </view>
          <text class="progress-text">{{fragmentText}}</text>
        </view>

        <view class="main-btn secondary" hover-class="menu-row-flash-secondary" bindtap="onSettings">设置</view>
      </view>

      <view class="main-footer-row">
        <view class="main-footer-side main-footer-side-left">
          <view class="main-link-btn" hover-class="link-btn-flash" bindtap="onReset">重置进度</view>
        </view>
        <text class="main-footer-divider">-</text>
        <view class="main-footer-side main-footer-side-right">
          <view class="main-link-btn-wrap">
            <view class="main-link-btn" hover-class="link-btn-flash" bindtap="onTasks">任务</view>
            <view wx:if="{{showClaimableDot}}" class="claimable-dot footer-claimable-dot"></view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 婵炲濮鹃褎鎱ㄩ悢鍏碱棃闁靛繆鍓濈欢?-->

  <!-- 闁荤姳绀佹晶浠嬫偪閸℃稒顥堥柕蹇婂墲缁?-->

  <cover-view wx:if="{{!menuMode}}" class="skip-btn" style="top: {{skipBtnTop}}px;" bindtap="onSkipIntro">跳过开场</cover-view>

</view>

<root-portal wx:if="{{pageTransition.active}}" class="page-transition-portal">
  <cover-view
    class="page-transition-overlay {{pageTransition.mode === 'black' ? 'fade-to-black' : 'fade-to-warm'}}"
    style="opacity: {{pageTransition.opacity}};"
    catchtouchmove="_blockTransitionTouch"
  ></cover-view>
</root-portal>
