/* 对齐 H5 css/levels.css */
page {
  height: 100%;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  background: transparent;
}

.levels-page {
  --dawn-pink: #F5E6E0;
  --rice-wine-gold: #E8C873;
  --caramel-brown: #A67C52;
  --old-wood: #6B5344;
  --milk-foam: #FFFDF7;
  --moss-green: #7BA37B;
  --chapter-accent: #E8C873;
  --chapter-glow: rgba(232, 200, 115, 0.2);
  --chapter-bg: #FDF8E8;
  position: relative;
  min-height: 100vh;
  background: var(--chapter-bg);
  color: var(--old-wood);
  overflow: hidden;
  transition: background-color 0.6s ease;
}

/* dairy 主题：SVG 已提供完整天空+山丘，页面本身设为透明 */
.theme-dairy {
  --chapter-accent: #E8C873;
  --chapter-glow: rgba(232, 200, 115, 0.2);
  --chapter-bg: transparent;
}

.theme-dairy {
  --chapter-accent: #E8C873;
  --chapter-glow: rgba(232, 200, 115, 0.2);
  --chapter-bg: #FDF8E8;
}

.theme-floral {
  --chapter-accent: #D4A0A8;
  --chapter-glow: rgba(212, 160, 168, 0.2);
  --chapter-bg: #FDF0F2;
}
.theme-floral .levels-bg {
  background: linear-gradient(180deg, #FDF0F2 0%, #F8E4E8 50%, #F0D4DA 100%);
}

.theme-fruit {
  --chapter-accent: #7BA37B;
  --chapter-glow: rgba(123, 163, 123, 0.2);
  --chapter-bg: #F0F5EC;
}
.theme-fruit .levels-bg {
  background: linear-gradient(180deg, #F0F5EC 0%, #E4F0D8 50%, #D4E8C0 100%);
}

.theme-grain {
  --chapter-accent: #D4A03A;
  --chapter-glow: rgba(212, 160, 58, 0.2);
  --chapter-bg: #F8F2E4;
}
.theme-grain .levels-bg {
  background: linear-gradient(180deg, #F8F2E4 0%, #F0E4C8 50%, #E8D4A8 100%);
}

.theme-temperature {
  --chapter-accent: #89B4C8;
  --chapter-glow: rgba(137, 180, 200, 0.2);
  --chapter-bg: #EDF4F7;
}
.theme-temperature .levels-bg {
  background: linear-gradient(180deg, #EDF4F7 0%, #D8EBF5 50%, #C4DFEF 100%);
}

.theme-ultimate {
  --chapter-accent: #E8A87C;
  --chapter-glow: rgba(232, 168, 124, 0.2);
  --chapter-bg: #FDF4EC;
}
.theme-ultimate .levels-bg {
  background: linear-gradient(180deg, #FDF4EC 0%, #F8E4D4 50%, #F0D0B4 100%);
}

/* 粒子 canvas：固定在最上层，pointer-events:none 让触摸穿透到 UI
   canvas 只画透明粒子（不画不透明背景），背景由 CSS 提供 */
.bubble-canvas-stack {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 100;
  pointer-events: none;
}

.bubble-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

/* 背景容器（fixed 铺满全屏，CSS 提供非 dairy 主题的渐变底） */
.levels-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
}

/* dairy 主题的 SVG 山丘图片：铺满整个背景容器 */
.levels-hills-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 750rpx;
  margin: 0 auto;
  padding: 16rpx 32rpx 32rpx;
  height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ========== 头部 ========== */
.header {
  position: relative;
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-bottom: 80rpx;
  box-sizing: content-box;
  z-index: 2;
}

.back-btn {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  background: var(--milk-foam);
  border: 1rpx solid rgba(166, 124, 82, 0.15);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(107, 83, 68, 0.05);
}

.back-arrow {
  font-size: 32rpx;
  color: var(--caramel-brown);
  line-height: 1;
}

.claimable-dot {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: radial-gradient(circle, #a8f0d0 30%, #5cc9a0 100%);
  box-shadow: 0 0 6rpx 2rpx rgba(92, 201, 160, 0.6);
  animation: claimableDotBreathe 1.6s ease-in-out infinite;
  pointer-events: none;
  z-index: 5;
}

@keyframes claimableDotBreathe {
  0%, 100% {
    transform: scale(0.8);
    opacity: 0.6;
    box-shadow: 0 0 4rpx 2rpx rgba(92, 201, 160, 0.4);
  }
  50% {
    transform: scale(1.25);
    opacity: 1;
    box-shadow: 0 0 12rpx 4rpx rgba(92, 201, 160, 0.85);
  }
}

.page-title-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.page-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 400;
  letter-spacing: 12rpx;
  padding-right: 12rpx;
  color: var(--old-wood);
  font-family: "Source Han Serif SC", "Noto Serif SC", "SimSun", serif;
  white-space: nowrap;
}

/* ========== 世界选择条 ========== */
.chapter-selector {
  flex-shrink: 0;
  margin-bottom: 72rpx;
}

.world-map {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.world-node {
  position: relative;
  flex: 0 0 auto;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--milk-foam);
  border: 3rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(107, 83, 68, 0.06);
  box-sizing: border-box;
}

.world-icon {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 36rpx;
  line-height: 1;
}

.world-node.active {
  border-color: var(--chapter-accent);
  box-shadow: 0 0 0 4rpx var(--chapter-glow);
}

.world-node.locked {
  opacity: 0.35;
  filter: grayscale(40%);
}

.world-check {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  width: 32rpx;
  height: 32rpx;
  background: var(--moss-green);
  color: #fff;
  border-radius: 50%;
  font-size: 18rpx;
  line-height: 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 8rpx rgba(123, 163, 123, 0.3);
}

/* ========== 章节头 ========== */
.chapter-header {
  position: relative;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  margin-bottom: 48rpx;
  padding: 56rpx 48rpx 48rpx;
}

.chapter-header::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: var(--chapter-accent);
  border-radius: 2rpx;
}

.chapter-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 15%;
  right: 15%;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(166, 124, 82, 0.15) 30%,
    rgba(166, 124, 82, 0.15) 70%,
    transparent 100%
  );
}

.chapter-icon {
  font-size: 100rpx;
  line-height: 1;
  margin-bottom: 24rpx;
}

.chapter-name {
  display: block;
  font-size: 50rpx;
  font-weight: 300;
  color: var(--old-wood);
  letter-spacing: 22rpx;
  text-indent: 22rpx;
  margin-bottom: 20rpx;
  font-family: "Source Han Serif SC", "Noto Serif SC", "SimSun", serif;
}

.chapter-desc {
  display: block;
  font-size: 23rpx;
  color: var(--caramel-brown);
  line-height: 2;
  letter-spacing: 4rpx;
  opacity: 0.7;
  font-style: italic;
  max-width: 500rpx;
  margin: 0 auto;
}

/* ========== 滑动提示 ========== */
.level-hint {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.hint-line {
  flex: 0 1 120rpx;
  max-width: 120rpx;
  width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--caramel-brown), transparent);
  opacity: 0.2;
}

.hint-text {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--caramel-brown);
  letter-spacing: 4rpx;
  opacity: 0.6;
}

/* ========== 关卡 carousel ========== */
.level-carousel-container {
  position: relative;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.level-carousel {
  height: 100%;
}

.level-spacer {
  height: 240rpx;
  flex-shrink: 0;
}

.level-door {
  position: relative;
  background-color: #FFFDF7;  /* 实心白，不透明 */
  border-radius: 28rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx;
  margin-bottom: 28rpx;
  border: 2rpx solid rgba(166, 124, 82, 0.10);
  min-height: 180rpx;
  flex-shrink: 0;
  transform: scale(0.96);
  box-shadow: 0 6rpx 32rpx rgba(107, 83, 68, 0.10), 0 2rpx 8rpx rgba(107, 83, 68, 0.06);
  box-sizing: border-box;
  transition: opacity 0.15s ease-out, transform 0.15s ease-out;
}

.level-door.selected {
  border-color: var(--chapter-accent);
  box-shadow:
    0 8rpx 32rpx rgba(107, 83, 68, 0.12),
    0 16rpx 56rpx var(--chapter-glow),
    0 0 0 2rpx var(--chapter-glow);
}

.level-door.locked {
  opacity: 0.3;
}

.level-door.locked .door-frame {
  filter: grayscale(80%) brightness(0.85);
}

.level-door.completed.selected {
  border-color: var(--moss-green);
}

.door-frame {
  width: 132rpx;
  height: 132rpx;
  min-width: 132rpx;
  background: linear-gradient(145deg, var(--milk-foam) 0%, var(--chapter-bg) 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(166, 124, 82, 0.05);
  margin-right: 28rpx;
  box-shadow: inset 0 4rpx 8rpx rgba(255, 255, 255, 0.4);
}

.door-icon {
  font-size: 56rpx;
}

.door-info {
  flex: 1;
  text-align: left;
  min-width: 0;
  overflow: hidden;
}

.door-name {
  display: block;
  font-size: 30rpx;
  font-weight: 400;
  color: var(--old-wood);
  margin-bottom: 10rpx;
  letter-spacing: 4rpx;
  font-family: "Source Han Serif SC", "Noto Serif SC", "PingFang SC", serif;
}

.door-target {
  display: block;
  font-size: 24rpx;
  color: var(--caramel-brown);
  letter-spacing: 2rpx;
  opacity: 0.75;
}

.door-enter-btn {
  flex: 0 0 auto;
  flex-shrink: 0;
  position: relative;
  width: auto;
  padding: 18rpx 36rpx;
  background: var(--chapter-accent);
  color: var(--old-wood);
  border-radius: 36rpx;
  font-size: 24rpx;
  font-weight: 400;
  letter-spacing: 6rpx;
  margin-left: 12rpx;
  box-shadow: 0 8rpx 24rpx var(--chapter-glow);
  line-height: 1.2;
  text-align: center;
  white-space: nowrap;
  overflow: visible;
}

/* 光波子元素（替代不支持的 ::before/::after） */
.btn-pulse-wave {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100%;
  height: 100%;
  border: 3rpx solid var(--chapter-accent);
  border-radius: 36rpx;
  opacity: 0;
  pointer-events: none;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
}

.btn-pulse-a {
  animation: btnPulseWave 2s ease-out infinite;
}

.btn-pulse-b {
  animation: btnPulseWave 2s ease-out infinite;
  animation-delay: 1s;
}

@keyframes btnPulseWave {
  0% {
    width: 100%;
    height: 100%;
    opacity: 0.75;
    border-width: 3rpx;
  }
  100% {
    width: 190%;
    height: 210%;
    opacity: 0;
    border-width: 1rpx;
  }
}

.completed-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  min-width: 40rpx;
  height: 40rpx;
  background: var(--moss-green);
  color: #fff;
  border-radius: 20rpx;
  font-size: 20rpx;
  line-height: 40rpx;
  text-align: center;
  padding: 0 10rpx;
  z-index: 15;
  box-shadow: 0 4rpx 12rpx rgba(123, 163, 123, 0.3);
}

/* ========== 顶栏红字提示 ========== */
.global-top-hint {
  position: fixed;
  left: 50%;
  top: max(22vh, 224rpx);
  transform: translateX(-50%);
  z-index: 9999;
  width: min(96vw, 720rpx);
  max-width: min(96vw, 720rpx);
  padding: 24rpx 56rpx;
  box-sizing: border-box;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.5;
  letter-spacing: 0.06em;
  color: #ff2d2d;
  text-shadow:
    0 0 14px rgba(255, 255, 255, 0.9),
    0 0 28px rgba(255, 82, 82, 0.55),
    0 1px 2px rgba(120, 0, 0, 0.35);
  pointer-events: none;
  opacity: 0;
}

.global-top-hint.visible {
  opacity: 1;
}

.global-top-hint.fade {
  opacity: 0;
  transition: opacity 1s ease-out;
}
