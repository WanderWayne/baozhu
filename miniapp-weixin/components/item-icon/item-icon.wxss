.item-icon-root {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-icon-png {
  font-size: 0;
}

.item-icon-image {
  width: 100%;
  height: 100%;
  display: block;
}

.item-icon-text {
  font-size: inherit;
  line-height: 1;
}

.item-icon-emoji .item-icon-text {
  font-size: 100%;
}
